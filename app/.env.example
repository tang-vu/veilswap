# Frontend build config. Vite inlines VITE_* variables into the public bundle —
# nothing here is a secret, and nothing secret belongs here.
# Copy to app/.env for local dev; on GitHub Pages these come from repository
# variables wired up in .github/workflows/deploy-app-pages.yml.

# WalletConnect / Reown project id — a public client identifier.
# Get a free one at https://cloud.reown.com (Create project → type "AppKit").
# Without it, injected wallets (MetaMask, Rabby) still work, but mobile QR
# pairing is disabled and WalletConnect's config call 4xxs in the console.
VITE_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC. Defaults to https://sepolia.drpc.org, whose free tier serves the
# wide eth_getLogs range queries the observer's ledger needs. Point this at a
# dedicated endpoint if the ledger feels slow during a live demo.
VITE_SEPOLIA_RPC_URL=
