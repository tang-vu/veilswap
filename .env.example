# RPC endpoint for Ethereum Sepolia (any provider works; publicnode is the default fallback)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployer account (funded with Sepolia ETH). Used by `pnpm deploy:sepolia`.
PRIVATE_KEY=

# Keeper account that triggers epoch lock/settlement (can be the same as PRIVATE_KEY).
KEEPER_PRIVATE_KEY=

# Etherscan API key (v2) for contract verification.
ETHERSCAN_API_KEY=

# Deployed VeilSwapPair address (set after `pnpm deploy:sepolia`; consumed by the keeper).
VEILSWAP_PAIR_ADDRESS=
